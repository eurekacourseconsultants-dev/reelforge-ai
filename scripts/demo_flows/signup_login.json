{
  "id": "signup_login",
  "start_url": "https://launchsteady.sg/",
  "steps": [
    {
      "id": "landing_land",
      "desc": "Land on the homepage",
      "action": "navigate",
      "url": "https://launchsteady.sg/"
    },
    {
      "id": "landing_scroll_pricing",
      "desc": "Scroll: hero -> comparison section (no delay) -> Professional card (settle before click)",
      "action": "scroll_into_view",
      "legs": [
        {
          "target": "#comparison",
          "block": "start",
          "nav_offset": 90,
          "duration": 600,
          "delay_after_ms": 550
        },
        {
          "target": ".pricing-grid > div:nth-child(2)",
          "block": "start",
          "nav_offset": 90,
          "duration": 600,
          "delay_after_ms": 200
        }
      ],
      "mobile_legs": [
        {
          "target": "#comparison",
          "block": "start",
          "nav_offset": 90,
          "duration": 600,
          "delay_after_ms": 550
        },
        {
          "target": ".pricing-grid > div:nth-child(2)",
          "block": "start",
          "nav_offset": 90,
          "duration": 600,
          "delay_after_ms": 200
        }
      ],
      "final_settle_ms": 550
    },
    {
      "id": "landing_cta",
      "desc": "Click Start free trial on the Professional card",
      "action": "click_navigate",
      "selector": ".pricing-grid > div:nth-child(2) a.btn",
      "expected_url_contains": "/signup"
    },
    {
      "id": "landing_cta_post_wait",
      "desc": "Brief pause on signup page after CTA click before continuing",
      "action": "wait",
      "duration": 450
    },
    {
      "id": "signup_fullname",
      "desc": "Type full name",
      "action": "type",
      "selector": "#fullName",
      "value": "{{demo_full_name}}"
    },
    {
      "id": "signup_email",
      "desc": "Type email address",
      "action": "type",
      "selector": "#email",
      "value": "{{demo_email}}"
    },
    {
      "id": "signup_country",
      "desc": "Select Singapore country code",
      "action": "select",
      "selector": "select:not(#gender)",
      "value": "Singapore"
    },
    {
      "id": "signup_phone",
      "desc": "Type phone number",
      "action": "type",
      "selector": "#phone",
      "value": "{{demo_phone}}"
    },
    {
      "id": "signup_gender",
      "desc": "Select gender",
      "action": "select",
      "selector": "#gender",
      "value": "female"
    },
    {
      "id": "signup_address",
      "desc": "Type address",
      "action": "type",
      "selector": "#address",
      "value": "{{demo_address}}"
    },
    {
      "id": "signup_postal",
      "desc": "Type postal code",
      "action": "type",
      "selector": "#postalCode",
      "value": "{{demo_postal_code}}"
    },
    {
      "id": "signup_password",
      "desc": "Type password",
      "action": "type",
      "selector": "#password",
      "value": "{{demo_password}}"
    },
    {
      "id": "signup_confirm_password",
      "desc": "Confirm password",
      "action": "type",
      "selector": "#confirmPassword",
      "value": "{{demo_password}}"
    },
    {
      "id": "signup_terms",
      "desc": "Tick the terms checkbox \u2014 click the outer div that wraps the custom checkbox",
      "action": "click_by_text",
      "containsText": "I have read and agree",
      "clickAncestor": true
    },
    {
      "id": "signup_submit",
      "desc": "Click Continue to create account",
      "action": "click_navigate",
      "selector": "button[type=submit]",
      "expected_url_contains": "/onboarding/package"
    },
    {
      "id": "package_land",
      "desc": "Hold on package selection page",
      "action": "wait",
      "duration": 400
    },
    {
      "id": "package_scroll",
      "desc": "Scroll to Professional package card",
      "action": "scroll",
      "target": ".package-grid > div:nth-child(3)"
    },
    {
      "id": "package_select",
      "desc": "Click Professional plan \u2014 3rd package card button",
      "action": "click_navigate",
      "selector": ".package-grid > div:nth-child(3) button.btn",
      "expected_url_contains": "/onboarding/billing"
    },
    {
      "id": "billing_land",
      "desc": "Hold on billing page",
      "action": "wait",
      "duration": 400
    },
    {
      "id": "billing_visual_click",
      "desc": "Visual click on billing CTA \u2014 no actual submission",
      "action": "visual_click",
      "selector": ".auth-form button[type=submit]"
    },
    {
      "id": "billing_hold",
      "desc": "Hold on billing page",
      "action": "wait",
      "duration": 300
    },
    {
      "id": "success_navigate",
      "desc": "Navigate to success page to show account created",
      "action": "navigate",
      "url": "https://launchsteady.sg/onboarding/success"
    },
    {
      "id": "success_hold",
      "desc": "Hold on success page",
      "action": "wait",
      "duration": 300
    },
    {
      "id": "success_signin",
      "desc": "Click Sign in to continue button on success page",
      "action": "click_navigate",
      "selector": ".btn.btn-accent.btn-full",
      "expected_url_contains": "/login"
    },
    {
      "id": "login_page_settle",
      "desc": "Wait for login page to fully load",
      "action": "wait",
      "duration": 450
    },
    {
      "id": "login_email",
      "desc": "Type email on login page",
      "action": "type",
      "selector": "#email",
      "value": "{{demo_email}}"
    },
    {
      "id": "login_password",
      "desc": "Type password on login page",
      "action": "type",
      "selector": "#password",
      "value": "{{demo_password}}"
    },
    {
      "id": "login_hover_submit",
      "desc": "Hover over login submit \u2014 do not click",
      "action": "hover",
      "selector": "button[type=submit]"
    },
    {
      "id": "login_hold",
      "desc": "Hold on login page to end demo",
      "action": "wait",
      "duration": 300
    }
  ]
}