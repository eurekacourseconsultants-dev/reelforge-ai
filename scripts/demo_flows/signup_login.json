{
  "id": "signup_login",
  "title": "Signup + Login",
  "phases": [
    1
  ],
  "baseUrl": "https://launchsteady.sg",
  "viewport": {
    "width": 1280,
    "height": 800
  },
  "steps": [
    {
      "id": "landing_land",
      "screen": "/",
      "action": "navigate",
      "description": "Land on launchsteady.sg homepage \u2014 hold on hero",
      "camera": {
        "type": "pan",
        "direction": "top-to-bottom",
        "duration": 2.5
      }
    },
    {
      "id": "landing_scroll_pricing",
      "screen": "/",
      "action": "scroll",
      "scrollTo": "#pricing",
      "description": "Scroll down slowly through features to pricing section",
      "scrollSteps": 12,
      "scrollDelay": 300,
      "camera": {
        "type": "pan",
        "direction": "top-to-bottom",
        "duration": 4.0
      }
    },
    {
      "id": "landing_cta",
      "screen": "/",
      "action": "click",
      "selector": "#pricing a.btn.btn-accent.btn-full",
      "description": "Zoom into Standard plan Start free trial \u2014 click it",
      "camera": {
        "type": "zoom",
        "target": "#pricing a.btn.btn-accent.btn-full",
        "holdBefore": 0.8,
        "holdAfter": 1.0
      }
    },
    {
      "id": "signup_land",
      "screen": "/signup",
      "action": "navigate",
      "description": "Land on signup page",
      "camera": {
        "type": "pan",
        "direction": "top-to-bottom",
        "duration": 2.0
      }
    },
    {
      "id": "signup_fullname",
      "screen": "/signup",
      "action": "type",
      "selector": "#fullName",
      "value": "{{demo_full_name}}",
      "description": "Type full name",
      "camera": {
        "type": "zoom",
        "target": "#fullName",
        "holdBefore": 0.5,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_email",
      "screen": "/signup",
      "action": "type",
      "selector": "#email",
      "value": "{{demo_email}}",
      "description": "Type email address",
      "camera": {
        "type": "zoom",
        "target": "#email",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_country",
      "screen": "/signup",
      "action": "select",
      "selector": "select",
      "value": "Singapore",
      "description": "Select country for phone",
      "camera": {
        "type": "zoom",
        "target": "select",
        "holdBefore": 0.3,
        "holdAfter": 0.5
      }
    },
    {
      "id": "signup_phone",
      "screen": "/signup",
      "action": "type",
      "selector": "#phone",
      "value": "{{demo_phone}}",
      "description": "Type phone number",
      "camera": {
        "type": "zoom",
        "target": "#phone",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_gender",
      "screen": "/signup",
      "action": "select",
      "selector": "#gender",
      "value": "female",
      "description": "Select gender",
      "camera": {
        "type": "zoom",
        "target": "#gender",
        "holdBefore": 0.3,
        "holdAfter": 0.5
      }
    },
    {
      "id": "signup_address",
      "screen": "/signup",
      "action": "type",
      "selector": "#address",
      "value": "{{demo_address}}",
      "description": "Type address",
      "camera": {
        "type": "zoom",
        "target": "#address",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_postal",
      "screen": "/signup",
      "action": "type",
      "selector": "#postalCode",
      "value": "{{demo_postal_code}}",
      "description": "Type postal code",
      "camera": {
        "type": "zoom",
        "target": "#postalCode",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_password",
      "screen": "/signup",
      "action": "type",
      "selector": "#password",
      "value": "{{demo_password}}",
      "description": "Type password",
      "camera": {
        "type": "zoom",
        "target": "#password",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_confirm_password",
      "screen": "/signup",
      "action": "type",
      "selector": "#confirmPassword",
      "value": "{{demo_password}}",
      "description": "Confirm password",
      "camera": {
        "type": "zoom",
        "target": "#confirmPassword",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "signup_terms",
      "screen": "/signup",
      "action": "click",
      "selector": "div[style*='border-radius:8px']",
      "description": "Tick terms and conditions",
      "camera": {
        "type": "zoom",
        "target": ".auth-card > div[style*='backgroundColor']",
        "holdBefore": 0.5,
        "holdAfter": 1.0
      }
    },
    {
      "id": "signup_cta_hold",
      "screen": "/signup",
      "action": "hover",
      "selector": "button[type='submit']",
      "description": "Move cursor to Continue button \u2014 do not click",
      "camera": {
        "type": "zoom",
        "target": "button[type='submit']",
        "holdBefore": 0.5,
        "holdAfter": 1.5
      }
    },
    {
      "id": "package_land",
      "screen": "/onboarding/package",
      "action": "navigate",
      "description": "Navigate to package selection page",
      "camera": {
        "type": "pan",
        "direction": "left-to-right",
        "duration": 2.5
      }
    },
    {
      "id": "package_basic",
      "screen": "/onboarding/package",
      "action": "hover",
      "selector": ".package-grid > div:nth-child(1)",
      "description": "Pan over Basic plan",
      "camera": {
        "type": "zoom",
        "target": ".package-card:nth-child(1)",
        "holdBefore": 0.3,
        "holdAfter": 1.0
      }
    },
    {
      "id": "package_standard",
      "screen": "/onboarding/package",
      "action": "hover",
      "selector": ".package-grid > div:nth-child(2)",
      "description": "Settle on Standard plan",
      "camera": {
        "type": "zoom",
        "target": ".package-card:nth-child(2)",
        "holdBefore": 0.3,
        "holdAfter": 1.5
      }
    },
    {
      "id": "package_pro",
      "screen": "/onboarding/package",
      "action": "hover",
      "selector": ".package-grid > div:nth-child(3)",
      "description": "Pan over Professional plan",
      "camera": {
        "type": "zoom",
        "target": ".package-card:nth-child(3)",
        "holdBefore": 0.3,
        "holdAfter": 1.0
      }
    },
    {
      "id": "package_cta_hold",
      "screen": "/onboarding/package",
      "action": "hover",
      "selector": ".package-grid > div:nth-child(2) button",
      "description": "Cursor settles on Standard CTA \u2014 do not click",
      "camera": {
        "type": "zoom",
        "target": ".package-card:nth-child(2) button",
        "holdBefore": 0.5,
        "holdAfter": 1.5
      }
    },
    {
      "id": "billing_land",
      "screen": "/onboarding/billing",
      "action": "navigate",
      "description": "Navigate to billing page",
      "camera": {
        "type": "pan",
        "direction": "top-to-bottom",
        "duration": 1.5
      },
      "seedSessionStorage": {
        "ls_package": "B",
        "ls_signup_from_variables": true
      }
    },
    {
      "id": "billing_summary",
      "screen": "/onboarding/billing",
      "action": "hover",
      "selector": ".billing-summary",
      "description": "Zoom into billing summary \u2014 highlight $0 due today",
      "camera": {
        "type": "zoom",
        "target": ".billing-summary",
        "holdBefore": 0.5,
        "holdAfter": 2.0
      }
    },
    {
      "id": "billing_card",
      "screen": "/onboarding/billing",
      "action": "hover",
      "selector": ".card-element-wrapper",
      "description": "Zoom into card field",
      "camera": {
        "type": "zoom",
        "target": ".card-element-wrapper",
        "holdBefore": 0.5,
        "holdAfter": 1.5
      }
    },
    {
      "id": "billing_cta_hold",
      "screen": "/onboarding/billing",
      "action": "hover",
      "selector": ".auth-form button.btn-accent",
      "description": "Cursor settles on Start free trial \u2014 do not click",
      "camera": {
        "type": "zoom",
        "target": "button[type='submit']",
        "holdBefore": 0.5,
        "holdAfter": 1.5
      }
    },
    {
      "id": "success_land",
      "screen": "/onboarding/success",
      "action": "navigate",
      "description": "Navigate to success page",
      "camera": {
        "type": "zoom",
        "target": ".auth-card",
        "holdBefore": 0.5,
        "holdAfter": 3.0
      }
    },
    {
      "id": "login_land",
      "screen": "/login",
      "action": "navigate",
      "description": "Navigate to login page",
      "camera": {
        "type": "pan",
        "direction": "top-to-bottom",
        "duration": 1.5
      }
    },
    {
      "id": "login_email",
      "screen": "/login",
      "action": "type",
      "selector": "#email",
      "value": "{{demo_email}}",
      "description": "Type email on login form",
      "camera": {
        "type": "zoom",
        "target": "#email",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "login_password",
      "screen": "/login",
      "action": "type",
      "selector": "#password",
      "value": "{{demo_password}}",
      "description": "Type password on login form",
      "camera": {
        "type": "zoom",
        "target": "#password",
        "holdBefore": 0.3,
        "holdAfter": 0.8
      }
    },
    {
      "id": "login_cta_hold",
      "screen": "/login",
      "action": "hover",
      "selector": "button[type='submit']",
      "description": "Cursor settles on Sign in button \u2014 hold for narration finish",
      "camera": {
        "type": "zoom",
        "target": "button[type='submit']",
        "holdBefore": 0.5,
        "holdAfter": 2.0
      }
    }
  ]
}